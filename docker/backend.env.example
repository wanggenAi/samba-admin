# Required: generate and set a strong random secret (64+ chars recommended).
# Example: openssl rand -hex 48
APP_JWT_SECRET=replace-with-64-plus-random-chars
APP_JWT_EXPIRE_MINUTES=480

# CORS defaults (adjust for production).
APP_CORS_ORIGINS=*
APP_CORS_ALLOW_CREDENTIALS=false

# Runtime data and logs inside container (mapped to ./data on host).
APP_DATA_DIR=/app/backend/app/data
APP_LOG_DIR=/app/backend/app/data/logs
APP_LOG_FILE=backend.log
APP_LOG_LEVEL=INFO
APP_LOG_MAX_BYTES=10485760
APP_LOG_BACKUP_COUNT=20
APP_LOG_RETAIN_DAYS=7

# LDAP connection settings.
LDAP_HOST=10.211.55.10
LDAP_PORT=636
LDAP_USE_SSL=true
LDAP_START_TLS=false
LDAP_TLS_SKIP_VERIFY=true
LDAP_BIND_USER=Administrator@EXAMPLE.COM
LDAP_BIND_PASSWORD=replace-with-real-password
LDAP_BASE_DN=DC=example,DC=com

# Optional LDAP overrides.
# LDAP_USER_CONTAINER_DN=CN=Users,DC=example,DC=com
# LDAP_USER_UPN_SUFFIX=example.com

# Optional Samba compatibility settings (LDAP-first mode can keep defaults).
# SAMBA_SERVICE=samba-ad-dc
# SAMBA_CONF=/etc/samba/smb.conf
# SAMBA_TESTPARM=testparm
# ALLOW_APPLY=false
