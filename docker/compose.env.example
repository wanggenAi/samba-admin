# Docker Compose variable file (local, not committed).
# Copy to docker/compose.env and adjust values for this host.

# Backend env file path (app env variables)
BACKEND_ENV_FILE=docker/backend.env

# Host ports
BACKEND_PORT=8000
FRONTEND_PORT=5173

# Host-side backend persistent data path
BACKEND_DATA_PATH=./data

# Backend resource limits
BACKEND_CPUS=1.00
BACKEND_MEM_LIMIT=1g
BACKEND_MEM_RESERVATION=512m

# Frontend resource limits
FRONTEND_CPUS=0.50
FRONTEND_MEM_LIMIT=512m
FRONTEND_MEM_RESERVATION=256m
