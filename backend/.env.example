# LDAP connection (change if your AD/LDAP endpoint differs)
LDAP_HOST=10.211.55.10
LDAP_PORT=636
LDAP_USE_SSL=true
LDAP_START_TLS=false
LDAP_TLS_SKIP_VERIFY=true
LDAP_BIND_USER=Administrator@EVMS.BSTU.EDU
LDAP_BIND_PASSWORD=
LDAP_BASE_DN=DC=evms,DC=bstu,DC=edu

# Required: set real bind password before starting backend
# LDAP_BIND_PASSWORD=your_real_password

# Optional overrides (only set if you need custom containers/suffix)
# LDAP_USER_CONTAINER_DN=CN=Users,DC=example,DC=com
# LDAP_USER_UPN_SUFFIX=example.com

# Samba compatibility settings (optional in current LDAP-only mode)
# SAMBA_SERVICE=samba-ad-dc
# SAMBA_CONF=/etc/samba/smb.conf
# SAMBA_TESTPARM=testparm
# ALLOW_APPLY=false
